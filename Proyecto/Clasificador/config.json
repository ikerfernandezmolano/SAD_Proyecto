{
    "data_file1": "../Datos/Spotify_Train.csv",
    "data_file2": "../Datos/Spotify_Dev.csv",
    "sep": ";",
    "algorithm": "logistic_regression",
    "prediction": "score",
    "f_score": "macro",
    "model": "output/Modelologistic_regression.pkl",
    "preprocessing": {
        "pnn": true,
        "sampling": "ADASYN",
        "scaler": "zscore",
        "unique_category_threshold": 10,
        "text_process": "tf-idf",
        "language": "english",
        "impute_num": "median",
        "impute_cat": "mode",
        "drop_features": ["reviewId"]
    },
    "kNN": {
        "k": {
            "kValues" : [],
            "valueMin": 1,
            "valueMax": 13,
            "step": 2
        },
        "weights": ["uniform","distance"],
        "p": [1,2]
    },
    "decision_tree": {
        "max_depth": [null, 10, 20, 50],
        "min_samples_split": [2, 5, 10],
        "min_samples_leaf": [1, 2, 4],
        "criterion": ["gini", "entropy"]
    },
    "random_forest": {
        "n_estimators": [100, 300, 500],
        "max_depth": [null, 10, 20, 50],
        "min_samples_split": [2, 5, 10],
        "min_samples_leaf": [1, 2, 4],
        "criterion": ["gini", "entropy"]
    },
    "naive_bayes": {
        "alpha": [1e-3,0.1,0.25,0.5,0.75,1.0],
        "fit_prior": [true, false]
    },
    "logistic_regression": {
        "C": [0.001, 0.01, 0.1, 1, 10, 100],
        "l1_ratio": [0, 1],
        "solver": ["lbfgs", "saga"],
        "max_iter" : [500,1000]
    }
}