{
    "data_file": "SantanderTraHalfHalf.csv",
    "algorithm": "kNN",
    "prediction": "TARGET",
    "f_score": "macro",
    "preprocessing": {
        "sampling": "oversampling",
        "scaler": "zscore",
        "unique_category_threshold": 20,
        "text_process": "tf-idf",
        "impute_num": "mean",     
        "impute_cat": "mode"      
    },
    "kNN": {
        "k": {
            "valueMin": 1,
            "valueMax": 5,
            "step": 2
        },
        "weights": ["uniform","distance"],
        "p": 2
    },
    "decision_tree": {
        "max_depth": [3, 5, 10],
        "min_samples_leaf": [1, 2],
        "criterion": ["gini", "entropy"]
    },
    "random_forest": {
        "n_estimators": [100,200],
        "max_depth": [20,30, null],
        "criterion": ["entropy"]
    },
    "naive_bayes": {
        "alpha": [1e-7,1.0]
    }
}