{
    "data_file": "orders.csv",
    "algorithm": "kNN",
    "prediction": "tshirt_category",
    "parameters": {
        "k": {
            "valueMin": 1,
            "valueMax": 5,
            "step": 2
        },
        "weights": ["uniform","distance"],
        "p": 2,
        "f_score": "weighted"
    },
    "preprocessing": {
          "scaler": "minmax",
          "text_process": "tf-idf",
          "unique_category_threshold": 20,
          "sampling": "oversampling"
    }
}